# Eagle Eye Configuration
# Copy this file to .env and adjust values for your setup

# ── CopyParty Backend ──────────────────────────────────────────
# Option A: Use an existing CopyParty instance (recommended if already running)
# For RAW previews (.NEF, etc), ensure ffmpeg + exiftool (+ libraw/imagemagick) are installed.
COPYPARTY_URL=http://localhost:3923

# Option B: Let Docker run CopyParty for you
# Uncomment and run: docker compose --profile bundled-copyparty up -d
# DATA_DIR=./data
# COPYPARTY_PORT=3923

# ── Eagle Eye Frontend ─────────────────────────────────────────
EAGLE_EYE_PORT=8080

# ── Companion API (drive management, optional) ─────────────────
# Enable with: docker compose --profile drives up -d
COMPANION_PORT=3924
COMPANION_API_URL=http://localhost:3924

# Where removable drives are mounted on the host (Linux only)
MEDIA_MOUNT_DIR=/mnt/media
