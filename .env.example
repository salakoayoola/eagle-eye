# Eagle Eye Configuration
# Copy this file to .env and adjust values for your setup

# ── CopyParty Backend ──────────────────────────────────────────
# Option A: Use an existing CopyParty instance (recommended if already running)
# For RAW previews (.NEF, etc), ensure ffmpeg + exiftool (+ libraw/imagemagick) are installed.
COPYPARTY_URL=http://localhost:3923

# Option B: Let Docker run CopyParty for you
# Uncomment and run: docker compose --profile bundled-copyparty up -d
# DATA_DIR=./data
# COPYPARTY_PORT=3923

# ── Eagle Eye Frontend ─────────────────────────────────────────
EAGLE_EYE_PORT=8080

# ── Companion API (drive management, optional) ─────────────────
# Enable with: docker compose --profile drives up -d
COMPANION_PORT=3924
COMPANION_API_URL=http://localhost:3924

# Required authentication for all Eagle Eye API endpoints.
# Set strong values before first run.
EAGLE_EYE_AUTH_USER=admin
EAGLE_EYE_AUTH_PASSWORD=change-me-now
# Generate with: openssl rand -base64 48
EAGLE_EYE_SESSION_SECRET=replace-with-long-random-secret
# Optional hardening knobs
EAGLE_EYE_SESSION_TTL_HOURS=12
# Set true when serving over HTTPS
EAGLE_EYE_SECURE_COOKIE=false
# Comma-separated origins allowed to call the API
EAGLE_EYE_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Where removable drives are mounted on the host (Linux only)
MEDIA_MOUNT_DIR=/mnt/media
