# Eagle Eye Configuration
# Copy this file to .env and adjust values for your setup

# Directory to serve files from (mounted into CopyParty container)
DATA_DIR=./data

# Port for the Eagle Eye web interface
EAGLE_EYE_PORT=8080

# CopyParty port (file server backend)
COPYPARTY_PORT=3923

# Companion API port (drive management, optional)
COMPANION_PORT=3924

# Where removable drives are mounted on the host (Linux only)
MEDIA_MOUNT_DIR=/mnt/media
